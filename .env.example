# ── Optional — only needed if you also want the Telegram control panel ────────
# Leave TELEGRAM_TOKEN blank to run in console-only / web-pair mode:
TELEGRAM_TOKEN=
OWNER_ID=

# ── Web pairing (no Telegram account needed) ───────────────────────────────
# Serves a simple pairing page at http://your-host:WEB_PORT/
# WEB_PAIR_CODE is a shared password required to use that page — required,
# because without it anyone who finds the URL could pair random numbers or
# delete your sessions. Pick something long and random.
WEB_PORT=3000
WEB_PAIR_CODE=change_this_to_something_random

# ── Optional (have defaults) ───────────────────────────────────
BOT_NAME=Alexa
PREFIX=.
MENU_IMAGE=https://link-to-your-image.jpg
REPORT_CHAT=your_telegram_user_id_here
OWNER_HANDLE=t.me/yourhandle
CHANNEL_LINK=https://t.me/yourchannel
GROUP_LINK=https://t.me/yourgroup

# ── ScottyHub site control (Settings → API Keys on the site) ──────────────────
# Key must belong to an admin account for the .site* commands to work.
SITE_API_URL=https://scottyhub.onrender.com/api
SITE_API_KEY=
